<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">
            <span>Linux Game Compat</span>
            <small>Source audit</small>
        </a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler"/>

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Lookup
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="games">
                <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Games
            </NavLink>
        </div>
        <AuthorizeView>
            <Authorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="favorites">
                        <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Favorites
                    </NavLink>
                </div>
                <div class="nav-item px-3 member-label">
                    <span class="member-label-content" title="@context.User.Identity?.Name">
                        <span class="bi bi-person-circle-nav-menu" aria-hidden="true"></span>
                        <span>@context.User.Identity?.Name</span>
                    </span>
                </div>
                <div class="nav-item px-3">
                    <form method="post" action="/logout">
                        <AntiforgeryToken />
                        <button class="nav-link logout-button" type="submit">
                            <span class="bi bi-box-arrow-right-nav-menu" aria-hidden="true"></span> Logout
                        </button>
                    </form>
                </div>
            </Authorized>
            <NotAuthorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="login">
                        <span class="bi bi-person-circle-nav-menu" aria-hidden="true"></span> Login
                    </NavLink>
                </div>
            </NotAuthorized>
        </AuthorizeView>
    </nav>
</div>
