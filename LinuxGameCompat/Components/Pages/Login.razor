@page "/login"
@using LinuxGameCompat.Services
@inject MagicLinkDisplayHandoff MagicLinkDisplayHandoff
<PageTitle>Login</PageTitle>

<section class="login-page">
	<div class="lookup-header">
		<p class="eyebrow">Member access</p>
		<h1>Login with your email</h1>
		<p class="lead">Enter your email address and we will send a one-time sign-in link.</p>
	</div>

	@if (Sent)
	{
		<div class="empty-state login-state login-state--success" role="status">
			<p class="empty-state-kicker">Link requested</p>
			<h2>Check your inbox</h2>
			@if (GeneratedLoginLink is not null)
			{
				<p>This deployment is configured to show test sign-in links in the frontend.</p>
				<div class="login-shortcut-warning">
					<p>Test shortcut: anyone with this link can sign in as the requested member.</p>
					<a class="login-shortcut-link" href="@GeneratedLoginLink.ToString()">@GeneratedLoginLink.ToString()</a>
				</div>
			}
			else
			{
				<p>If the address can receive member access links, a sign-in email is on its way.</p>
			}
		</div>
	}
	else
	{
		@if (Failed)
		{
			<div class="empty-state login-state login-state--warning" role="alert">
				<p class="empty-state-kicker">Expired link</p>
				<h2>That link did not work</h2>
				<p>Request a new sign-in link and use it within 15 minutes.</p>
			</div>
		}
		else if (RequestFailed)
		{
			<div class="empty-state login-state login-state--warning" role="alert">
				<p class="empty-state-kicker">Request failed</p>
				<h2>We could not send that link</h2>
				<p>Please check the email address and try again in a moment.</p>
			</div>
		}

		<form class="lookup-form login-form" method="post" action="/auth/magic-link/request">
			<input type="hidden" name="returnUrl" value="@SafeReturnUrl" />
			<label class="form-label" for="login-email">Email address</label>
			<div class="input-group">
				<input id="login-email"
					   class="form-control form-control-lg"
					   type="email"
					   name="email"
					   autocomplete="email"
					   required />
				<button class="btn btn-primary btn-lg" type="submit">Send link</button>
			</div>
		</form>
	}
</section>

@code {
	[SupplyParameterFromQuery(Name = "returnUrl")]
	private string? ReturnUrl { get; set; }

	[SupplyParameterFromQuery(Name = "sent")]
	private string? SentValue { get; set; }

	[SupplyParameterFromQuery(Name = "failed")]
	private string? FailedValue { get; set; }

	[SupplyParameterFromQuery(Name = "requestFailed")]
	private string? RequestFailedValue { get; set; }

	[CascadingParameter]
	private HttpContext? HttpContext { get; set; }

	private Uri? GeneratedLoginLink { get; set; }

	private bool Sent => SentValue == "1";

	private bool Failed => FailedValue == "1";

	private bool RequestFailed => RequestFailedValue == "1";

	private string SafeReturnUrl => LocalReturnUrlNormalizer.Normalize(ReturnUrl);

	protected override void OnInitialized()
	{
		if (Sent && HttpContext is not null && MagicLinkDisplayHandoff.TryConsume(HttpContext, out Uri? loginLink))
		{
			GeneratedLoginLink = loginLink;
		}
	}
}
